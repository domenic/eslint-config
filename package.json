{
  "name": "@domenic/eslint-config",
  "description": "Domenic Denicola's base ESLint config",
  "keywords": [
    "eslint",
    "lint",
    "style"
  ],
  "version": "4.1.0",
  "author": "Domenic Denicola <d@domenic.me> (https://domenic.me/)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domenic/eslint-config.git"
  },
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./stylistic": "./stylistic.mjs"
  },
  "files": [
    "index.mjs",
    "stylistic.mjs"
  ],
  "scripts": {
    "check-rules": "node scripts/check-rules.mjs ./index.mjs",
    "check-rules:stylistic": "node scripts/check-rules.mjs ./stylistic.mjs --stylistic"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.7.1",
    "eslint": "^9.39.2"
  },
  "peerDependencies": {
    "@stylistic/eslint-plugin": "^5.7.1",
    "eslint": "^9.39.2"
  },
  "peerDependenciesMeta": {
    "@stylistic/eslint-plugin": {
      "optional": true
    }
  }
}
